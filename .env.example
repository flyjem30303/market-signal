NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Keep this as mock until Supabase queries are implemented.
NEXT_PUBLIC_DATA_SOURCE=mock

# Keep disabled until CEO opens a bounded market-signal runtime-read checkpoint.
MARKET_SIGNAL_SUPABASE_READS=disabled

# Keep this as mock until Supabase freshness has passed db:freshness.
DATA_FRESHNESS_SOURCE=mock

# Keep disabled unless CEO opens a bounded runtime-read checkpoint.
DATA_FRESHNESS_SUPABASE_READS=disabled

# Disabled by default. Use only for local/server-side raw market diagnostics.
INTERNAL_DIAGNOSTICS_ENABLED=false
INTERNAL_DIAGNOSTICS_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public Beta packet window values. Non-secret; leave blank until a public Beta URL exists.
# BETA_HOSTING_PROJECT_NAME is the plain hosting project slug, not a URL or dashboard link.
# BETA_TEMPORARY_URL must be a public https preview/Beta URL, not localhost, Supabase dashboard, or a URL with tokens/query strings.
BETA_HOSTING_PROJECT_NAME=
BETA_TEMPORARY_URL=
