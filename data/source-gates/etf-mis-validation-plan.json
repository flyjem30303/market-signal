      "owner_role": "A",
      "status": "open",
      "required_for": "adapter-design",
      "description": "Confirm userDelay, cachedAlive, and timestamp behavior during and after market hours.",
      "evidence_required": [
        "during-market sample",
        "after-market sample",
        "cache behavior note"
      ]
    },
    {
      "id": "date-parameter-behavior",
      "owner_role": "A",
      "status": "open",
      "required_for": "adapter-design",
      "description": "Confirm whether the MIS disclosure surface supports historical dates or only latest data.",
      "evidence_required": [
        "tested URL variants",
        "result comparison",
        "latest-only conclusion if applicable"
      ]
    },
    {
      "id": "rate-limit-fair-use",
      "owner_role": "D",
      "status": "open",
      "required_for": "adapter-design",
      "description": "Confirm whether repeated internal validation calls are acceptable and define safe cadence.",
      "evidence_required": [
        "terms or fair-use note",
        "recommended max cadence",
        "backoff rule"
      ]
    },
    {
      "id": "license-redistribution",
      "owner_role": "D",
      "status": "open",
      "required_for": "ingestion",
      "description": "Confirm storage, analysis, public display, attribution, and redistribution permissions.",
      "evidence_required": [
        "terms URL",
        "storage permission",
        "public display permission",
        "attribution requirement"
      ]
    },
    {
      "id": "no-ingestion-guard",
      "owner_role": "E",
      "status": "approved",
      "required_for": "adapter-design",
      "description": "Validation work must not write ETF MIS payloads into Supabase or product seed data.",
      "evidence_required": [
        "plan states non-ingesting",
        "no database write path"
      ]
    }
