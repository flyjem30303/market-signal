{
  "name": "taiwan-market-signal",
  "version": "0.1.0",
  "private": true,
  "description": "Taiwan stock health and pullback-risk signal dashboard.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:json": "node -e \"const fs=require('fs'); for (const f of ['package.json','tsconfig.json','data/seeds/markets.seed.json','data/seeds/stocks.seed.json']) { JSON.parse(fs.readFileSync(f,'utf8')); console.log(f+' ok'); }\"",
    "check:asset-policy": "node --experimental-strip-types scripts/check-asset-type-policy.mjs",
    "check:etf-due-diligence": "node scripts/check-etf-due-diligence.mjs",
    "check:etf-source-gate": "node scripts/check-etf-source-gate.mjs",
    "check:env": "node -e \"const fs=require('fs'); const s=fs.readFileSync('.env.example','utf8'); for (const k of ['NEXT_PUBLIC_SUPABASE_URL','NEXT_PUBLIC_SUPABASE_ANON_KEY','SUPABASE_SERVICE_ROLE_KEY','NEXT_PUBLIC_DATA_SOURCE','DATA_FRESHNESS_SOURCE','INTERNAL_DIAGNOSTICS_ENABLED','INTERNAL_DIAGNOSTICS_TOKEN','NEXT_PUBLIC_SITE_URL']) { if (!s.includes(k+'=')) throw new Error('Missing '+k); console.log(k+' ok'); }\"",
    "check:internal-routes": "node scripts/check-internal-route-exposure.mjs",
    "db:bootstrap": "node scripts/build-supabase-bootstrap.mjs",
    "db:etf-schema": "node --env-file=.env.local scripts/check-supabase-etf-schema.mjs",
    "db:freshness": "node --env-file=.env.local scripts/check-supabase-freshness.mjs",
    "db:preflight": "node scripts/check-supabase-preflight.mjs",
    "db:raw-market": "node --env-file=.env.local scripts/check-supabase-raw-market.mjs",
    "db:split-bootstrap": "node scripts/split-supabase-bootstrap.mjs",
    "db:trust-review": "node --env-file=.env.local scripts/review-supabase-market-trust.mjs",
    "db:validate": "node --env-file=.env.local scripts/validate-supabase-bootstrap.mjs",
    "fetch:daily-market": "node scripts/fetch-twse-daily-market.mjs",
    "fetch:stocks": "node scripts/fetch-twse-stock-master.mjs",
    "env:init-local": "node scripts/init-local-env.mjs",
    "report:etf-source": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/report-etf-source-readiness.mjs",
    "seed:data-runs": "node scripts/seed-data-runs-sql.mjs",
    "seed:markets": "node scripts/seed-markets-sql.mjs",
    "seed:stocks": "node scripts/seed-stocks-sql.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "typescript": "^5.6.3"
  }
}
