    "fetch:daily-market": "node scripts/fetch-twse-daily-market.mjs",
    "fetch:stocks": "node scripts/fetch-twse-stock-master.mjs",
    "env:init-local": "node scripts/init-local-env.mjs",
    "report:cp3-tw-stock-dry-run": "node scripts/report-cp3-tw-stock-dry-run.mjs",
    "report:cp3-tw-stock-endpoint-metadata": "node scripts/report-cp3-tw-stock-endpoint-metadata.mjs",
    "report:cp3-tw-stock-historical-parameter": "node scripts/report-cp3-tw-stock-historical-parameter-probe.mjs",
    "report:cp3-twse-stock-day-metadata": "node scripts/report-cp3-twse-stock-day-metadata-probe.mjs",
