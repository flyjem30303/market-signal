    "check:cp3-tw-stock-endpoint-contract-matrix": "node scripts/check-cp3-tw-stock-endpoint-contract-matrix.mjs",
    "check:cp3-tw-stock-endpoint-metadata-probe": "node scripts/check-cp3-tw-stock-endpoint-metadata-probe.mjs",
    "check:cp3-tw-stock-legal-field-contract": "node scripts/check-cp3-tw-stock-legal-field-contract-review.mjs",
    "check:cp3-tw-stock-historical-parameter-probe-plan": "node scripts/check-cp3-tw-stock-historical-parameter-probe-plan.mjs",
