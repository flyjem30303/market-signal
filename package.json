    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:json": "node -e \"const fs=require('fs'); for (const f of ['package.json','tsconfig.json','data/seeds/markets.seed.json','data/seeds/stocks.seed.json']) { JSON.parse(fs.readFileSync(f,'utf8')); console.log(f+' ok'); }\"",
