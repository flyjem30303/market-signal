    "check:cp3-twse-stock-day-license-rate-field": "node scripts/check-cp3-twse-stock-day-license-rate-field-checklist.mjs",
    "check:cp3-twse-stock-day-controlled-ingestion-design": "node scripts/check-cp3-twse-stock-day-controlled-ingestion-design.mjs",
    "check:cp3-twse-stock-day-dry-run-reporter-design": "node scripts/check-cp3-twse-stock-day-dry-run-reporter-design.mjs",
