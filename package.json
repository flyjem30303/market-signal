    "check:cp3-tw-stock-model": "node scripts/check-cp3-tw-stock-model-candidates.mjs",
    "check:review-gates": "node scripts/check-review-gates.mjs",
    "check:freshness-state-ui": "node scripts/check-freshness-state-ui.mjs",
